{
    "compilerOptions": {
        "target": "ESNext",
        "useDefineForClassFields": true,
        "skipLibCheck": true,
        "module": "ESNext",
        "allowJs": false,
        "moduleResolution": "bundler",
        "strict": true,
        "jsx": "react-jsx",
        "sourceMap": false,
        "importHelpers": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "lib": ["DOM", "DOM.Iterable", "ESNext"],
        "outDir": "../dist",
        "forceConsistentCasingInFileNames": true,
        "noEmit": true,
        "types": ["@mastergo/plugin-typings"],
        "paths": {
            "@lib/*": ["./lib/*"],
            "@ui/*": ["./ui/*"],
            "@messages/*": ["./messages/*"]
        }
    },
    "include": [
        "./ui/**/*.ts",
        "./ui/**/*.tsx",
        "./typings/*.d.ts",
        "./lib/**/*.ts",
        "./messages/**/*.ts"
    ]
}
